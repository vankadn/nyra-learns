  "sections": [
    {
      "id": "short-vowels",
      "title": "Short Vowels",
      "color": "#FF7043",
      "icon": "🔴",
      "tip": "Short vowels make a quick, soft sound — like a little hiccup!",
      "rule": "Short vowels appear in closed syllables — a vowel followed by a consonant!",
      "vowels": [
        { "letter": "A", "example": "cat", "speak": "a as in cat" },
        { "letter": "E", "example": "bed", "speak": "e as in bed" },
        { "letter": "I", "example": "sit", "speak": "i as in sit" },
        { "letter": "O", "example": "hot", "speak": "o as in hot" },
        { "letter": "U", "example": "cup", "speak": "u as in cup" }
      ],
      "items": [
        { "id": "short-a", "label": "Short A — /ă/", "icon": "🐱", "words": ["cat","map","hand","bat","bag"] },
        { "id": "short-e", "label": "Short E — /ĕ/", "icon": "🛏️", "words": ["bed","ten","leg","red","hen"] },
        { "id": "short-i", "label": "Short I — /ĭ/", "icon": "🐟", "words": ["sit","fish","milk","big","win"] },
        { "id": "short-o", "label": "Short O — /ŏ/", "icon": "🐶", "words": ["top","dog","sock","hot","box"] },
        { "id": "short-u", "label": "Short U — /ŭ/", "icon": "☀️", "words": ["cup","sun","duck","bug","run"] }
      ]
    },
    {
      "id": "long-vowels",
      "title": "Long Vowels",
      "color": "#7C4DFF",
      "icon": "🟣",
      "tip": "Long vowels say their name — like when you say the alphabet!",
      "rule": "Magic E Rule: vowel + consonant + e = long vowel! The silent E at the end makes the vowel long!",
      "vowels": [
        { "letter": "A", "example": "cake", "speak": "long a, say A" },
        { "letter": "E", "example": "tree", "speak": "long e, say E" },
        { "letter": "I", "example": "bike", "speak": "long i, say I" },
        { "letter": "O", "example": "home", "speak": "long o, say O" },
        { "letter": "U", "example": "cute", "speak": "long u, say U" }
      ],
      "transforms": [
        { "before": "cap", "after": "cape" },
        { "before": "bit", "after": "bite" },
        { "before": "hop", "after": "hope" },
        { "before": "tub", "after": "tube" }
      ],
      "items": [
        { "id": "long-a", "label": "Long A — ā", "icon": "🎂", "words": ["cake","name","play","rain","day"] },
        { "id": "long-e", "label": "Long E — ē", "icon": "🌳", "words": ["tree","meet","seed","me","she"] },
        { "id": "long-i", "label": "Long I — ī", "icon": "🚲", "words": ["bike","time","five","hi","kite"] },
        { "id": "long-o", "label": "Long O — ō", "icon": "🏠", "words": ["home","boat","road","go","snow"] },
        { "id": "long-u", "label": "Long U — ū", "icon": "🌸", "words": ["cute","music","tube","use"] }
      ]
    },
    {
      "id": "vowel-teams",
      "title": "Vowel Teams",
      "color": "#0097A7",
      "icon": "🔵",
      "tip": "Two vowels work together to make one sound!",
      "items": [
        { "id": "ai-ay", "label": "ai / ay", "sound": "Long A sound (ā)", "words": ["rain","train","day","play","stay"] },
        { "id": "ee-ea", "label": "ee / ea", "sound": "Long E sound (ē)", "words": ["feet","bee","leaf","meat","seat"] },
        { "id": "oa-ow", "label": "oa / ow", "sound": "Long O sound (ō)", "words": ["boat","soap","snow","grow","blow"] },
        { "id": "oo",    "label": "oo",      "sound": "As in moon or book", "words": ["moon","spoon","food","book","look"] },
        { "id": "oi-oy", "label": "oi / oy", "sound": "\"oi\" sound",       "words": ["coin","boil","toy","boy","joy"] },
        { "id": "ou-ow", "label": "ou / ow", "sound": "As in \"ouch!\"",    "words": ["house","mouse","cloud","cow","town"] },
        { "id": "au-aw", "label": "au / aw", "sound": "\"aw\" sound",       "words": ["saw","draw","claw","August"] },
        { "id": "ei",    "label": "ei / eigh","sound": "Long A sound",      "words": ["vein","rein","eight","weight"] }
      ]
    }
  ],
